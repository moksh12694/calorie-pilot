{
  "expo": {
    "name": "CaloriePilot",
    "slug": "caloriepilot",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.caloriepilot.app",
      "infoPlist": {
        "NSMotionUsageDescription": "CaloriePilot uses motion data to count your daily steps."
      }
    },
    "android": {
      "package": "com.caloriepilot.app",
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow CaloriePilot to access your motion sensors for step tracking."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8080/api"
    }
  }
}
