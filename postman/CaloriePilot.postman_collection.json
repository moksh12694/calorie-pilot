        },
        {
          "name": "GET /meals/daily?date=...",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/meals/daily?date=2026-05-31",
              "host": ["{{baseUrl}}"], "path": ["meals", "daily"],
              "query": [{ "key": "date", "value": "2026-05-31" }]
            }
          }
        }
      ]
